# Ondial_Webhook — provider ingress (api.ondial.ai / dev-api.ondial.ai)

PORT=9000
MONGODB_URI=mongodb://user:pass@host/ondial
REDIS_URL=redis://localhost:6379
TRUST_PROXY=1

# Telephony ingress auth (existing)
# WEBHOOK_SHARED_SECRET=
# WEBHOOK_HMAC_SECRET=
# WEBHOOK_INTERNAL_SECRET=

# AiSensy inbound (same secret as AiSensy dashboard + Ondial WEBHOOK_SECRET + Calling_system1)
# Live ingress:  https://api.ondial.ai/api/webhook/aisensy
# Test ingress:  https://dev-api.ondial.ai/api/webhook/aisensy
WEBHOOK_SECRET=
# Optional alias:
# AISENSY_WEBHOOK_SECRET=

# BullMQ queue name consumed by Calling_system1 scheduler (must match)
AISENSY_INBOUND_QUEUE_NAME=aisensy-inbound
# AISENSY_INBOUND_MAX_RETRIES=5
# AISENSY_INBOUND_BASE_RETRY_MS=1000
# Note: AISENSY_API_KEY / PROJECT_ID are NOT used here — outbound AiSensy is Ondial + CS1.

# Ondial app callbacks (dashboard host)
# Live:  https://dashboard.ondial.ai
# Test:  https://dashboard-test.ondial.ai
ONDIAL_APP_URL=https://dashboard.ondial.ai
ANALYSIS_API_URL=https://sscript.ondial.ai
